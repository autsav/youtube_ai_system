          "title": "Premise",
          "type": "string"
        },
        "hook_script": {
          "title": "Hook Script",
          "type": "string"
        },
        "thumbnail_seed": {
          "title": "Thumbnail Seed",
          "type": "string"
        },
        "predicted_ctr_range": {
          "title": "Predicted Ctr Range",
          "type": "string"
        },
        "predicted_avd_range": {
          "title": "Predicted Avd Range",
          "type": "string"
        },
        "why_it_should_work": {
          "title": "Why It Should Work",
          "type": "string"
        }
      },
      "required": [
        "concept_id",
        "format",
        "title_options",
        "premise",
        "hook_script",
        "thumbnail_seed",
        "predicted_ctr_range",
        "predicted_avd_range",
