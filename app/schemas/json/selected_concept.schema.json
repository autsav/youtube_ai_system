          "type": "number"
        },
        "weight": {
          "minimum": 0.0,
          "title": "Weight",
          "type": "number"
        },
        "weighted_score": {
          "minimum": 0.0,
          "title": "Weighted Score",
          "type": "number"
        }
      },
      "required": [
        "raw_score",
        "weight",
        "weighted_score"
      ],
      "title": "ScoreComponent",
      "type": "object"
    },
