      "type": "object"
    },
    "scores": {
      "additionalProperties": {
        "type": "number"
      },
      "title": "Scores",
      "type": "object"
    },
    "winner_reason": {
      "title": "Winner Reason",
      "type": "string"
    }
  },
  "required": [
    "winner_id",
    "winner",
    "winner_reason"
