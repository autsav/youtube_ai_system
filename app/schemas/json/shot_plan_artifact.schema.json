{
  "$defs": {
    "AssetRequirement": {
      "properties": {
        "asset_id": {
          "title": "Asset Id",
          "type": "string"
        },
        "related_shot_id": {
          "title": "Related Shot Id",
          "type": "string"
        },
        "asset_type": {
          "enum": [
            "RECORDED_A_ROLL",
            "RECORDED_B_ROLL",
            "SCREEN_CAPTURE",
            "AI_GENERATED",
            "STOCK_LICENSED",
            "GRAPHIC_TEMPLATE"
          ],
          "title": "Asset Type",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "source_preference": {
          "title": "Source Preference",
          "type": "string"
        },
        "status": {
          "enum": [
            "pending",
            "in_progress",
            "ready",
            "blocked"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "asset_id",
        "related_shot_id",
        "asset_type",
        "description",
        "source_preference",
        "status"
      ],
      "title": "AssetRequirement",
      "type": "object"
    },
    "QuickBrollIdea": {
      "properties": {
        "idea_id": {
          "title": "Idea Id",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "intended_segment_id": {
          "title": "Intended Segment Id",
          "type": "string"
        },
        "suggested_asset_type": {
          "enum": [
            "B_ROLL",
            "AI_BROLL",
            "STOCK",
            "SCREEN_CAPTURE",
            "GRAPHIC"
          ],
          "title": "Suggested Asset Type",
          "type": "string"
        },
        "why_it_helps": {
          "title": "Why It Helps",
          "type": "string"
        }
      },
      "required": [
        "idea_id",
        "description",
        "intended_segment_id",
        "suggested_asset_type",
        "why_it_helps"
      ],
      "title": "QuickBrollIdea",
      "type": "object"
    },
    "TimelineBlock": {
      "properties": {
        "block_id": {
          "title": "Block Id",
          "type": "string"
        },
        "start_sec": {
          "minimum": 0,
          "title": "Start Sec",
          "type": "integer"
        },
        "end_sec": {
          "exclusiveMinimum": 0,
          "title": "End Sec",
          "type": "integer"
        },
        "purpose": {
          "title": "Purpose",
          "type": "string"
        },
        "pace": {
          "title": "Pace",
          "type": "string"
        },
        "visual_density": {
          "title": "Visual Density",
          "type": "string"
        },
        "primary_assets": {
          "items": {
            "type": "string"
          },
          "title": "Primary Assets",
          "type": "array"
        },
        "notes": {
          "title": "Notes",
          "type": "string"
        }
      },
      "required": [
        "block_id",
        "start_sec",
        "end_sec",
        "purpose",
        "pace",
        "visual_density",
        "notes"
      ],
      "title": "TimelineBlock",
      "type": "object"
    }
  },
  "properties": {
    "estimated_total_shots": {
      "minimum": 0,
      "title": "Estimated Total Shots",
      "type": "integer"
    },
    "estimated_a_roll_shots": {
      "minimum": 0,
      "title": "Estimated A Roll Shots",
      "type": "integer"
    },
    "estimated_b_roll_shots": {
      "minimum": 0,
      "title": "Estimated B Roll Shots",
      "type": "integer"
    },
    "estimated_ai_shots": {
      "minimum": 0,
      "title": "Estimated Ai Shots",
      "type": "integer"
    },
    "estimated_stock_shots": {
      "minimum": 0,
      "title": "Estimated Stock Shots",
      "type": "integer"
    },
    "production_notes": {
      "items": {
        "type": "string"
      },
      "title": "Production Notes",
      "type": "array"
    },
    "timeline_blocks": {
      "items": {
        "$ref": "#/$defs/TimelineBlock"
      },
      "title": "Timeline Blocks",
      "type": "array"
    },
    "quick_broll_ideas": {
      "items": {
        "$ref": "#/$defs/QuickBrollIdea"
      },
      "title": "Quick Broll Ideas",
      "type": "array"
    },
    "asset_requirements": {
      "items": {
        "$ref": "#/$defs/AssetRequirement"
      },
      "title": "Asset Requirements",
      "type": "array"
    }
  },
  "required": [
    "estimated_total_shots",
    "estimated_a_roll_shots",
    "estimated_b_roll_shots",
    "estimated_ai_shots",
    "estimated_stock_shots"
  ],
  "title": "ShotPlanArtifact",
  "type": "object"
}